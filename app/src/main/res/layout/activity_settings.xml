<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212"
    android:fitsSystemWindows="true">

    <!-- Explicit toolbar — avoids MIUI/edge-to-edge overlap with window decor bar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#1E1E1E"
        app:title="@string/settings_title"
        app:titleTextColor="#FFFFFF"
        app:navigationIconTint="#FFFFFF" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- ── Groq API キー ─────────────────────────────────────────── -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/settings_groq_key_section"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:endIconMode="password_toggle"
                app:boxStrokeColor="#555555"
                app:hintTextColor="#AAAAAA">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etGroqApiKey"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/settings_groq_key_hint"
                    android:inputType="textPassword"
                    android:fontFamily="monospace"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#888888" />

            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="6dp">

                <TextView
                    android:id="@+id/tvGroqKeyStatus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text=""
                    android:textColor="#9CA3AF"
                    android:textSize="11sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTestGroqKey"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="接続テスト"
                    android:textColor="#4CAF50"
                    android:textSize="12sp" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvGroqKeyLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:padding="4dp"
                android:text="🔑 Groq APIキーを取得 (console.groq.com/keys)"
                android:textColor="#4CAF50"
                android:textSize="12sp"
                android:background="?attr/selectableItemBackground" />

            <!-- ── 文字起こしモデル ──────────────────────────────────────── -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="@string/settings_model_section"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp" />

            <RadioGroup
                android:id="@+id/rgModel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <RadioButton
                    android:id="@+id/rbModelTurbo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_model_turbo"
                    android:textColor="#DDDDDD"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/rbModelFull"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_model_full"
                    android:textColor="#DDDDDD" />

            </RadioGroup>

            <!-- ── 要約エンジン ───────────────────────────────────────── -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="要約エンジン"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp" />

            <RadioGroup
                android:id="@+id/rgSummaryProvider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <RadioButton
                    android:id="@+id/rbSummaryNone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="使わない（自分で全文コピペ）"
                    android:textColor="#DDDDDD"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/rbSummaryGroq"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Groq (Llama 3.3 70B / 文字起こしキー流用)"
                    android:textColor="#DDDDDD" />

                <RadioButton
                    android:id="@+id/rbSummaryOpenai"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OpenAI (GPT-4o mini)"
                    android:textColor="#DDDDDD" />

                <RadioButton
                    android:id="@+id/rbSummaryClaude"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Anthropic Claude (Haiku 3.5)"
                    android:textColor="#DDDDDD" />

                <RadioButton
                    android:id="@+id/rbSummaryGemini"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Google Gemini (2.0 Flash)"
                    android:textColor="#DDDDDD" />

            </RadioGroup>

            <TextView
                android:id="@+id/tvSummaryKeyLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="要約用 API キー"
                android:textColor="#9CA3AF"
                android:textSize="12sp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilSummaryKey"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                app:endIconMode="password_toggle"
                app:hintEnabled="false"
                app:boxStrokeColor="#555555">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etSummaryApiKey"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="プロバイダ別の API キー"
                    android:inputType="textPassword"
                    android:fontFamily="monospace"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#888888" />

            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:id="@+id/llSummaryKeyActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="6dp">

                <TextView
                    android:id="@+id/tvSummaryKeyStatus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text=""
                    android:textColor="#9CA3AF"
                    android:textSize="11sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTestSummaryKey"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="接続テスト"
                    android:textColor="#4CAF50"
                    android:textSize="12sp" />

            </LinearLayout>

            <!-- ── バッテリー最適化 ──────────────────────────────────────── -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="@string/settings_battery_section"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvBatteryStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="#AAAAAA"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBatterySettings"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/settings_battery_action"
                android:textColor="#AAAAAA"
                app:strokeColor="#444444" />

            <!-- ── 文字起こしフィルタ ───────────────────────────────────── -->

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="32dp"
                android:background="#1F1F1F" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="文字起こしフィルタ"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="フィラー幻覚を除外 (ご視聴ありがとうございました 等)"
                    android:textColor="#DDDDDD"
                    android:textSize="13sp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchFillerFilter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="追加で除外する語句 (1行1つ)"
                android:textColor="#9CA3AF"
                android:textSize="12sp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                app:boxStrokeColor="#555555">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etFillerUserPatterns"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minLines="3"
                    android:gravity="top|start"
                    android:inputType="textMultiLine"
                    android:fontFamily="monospace"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRefilter"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="過去の文字起こしを再フィルタ"
                android:textColor="#FFA726"
                app:strokeColor="#FFA726" />

            <!-- ── 音声検出 (VAD) ──────────────────────────────────────── -->

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="32dp"
                android:background="#1F1F1F" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="音声検出 (VAD)"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="人の声がある区間だけ文字起こしする (無音・環境音はGroqに送らない)"
                    android:textColor="#DDDDDD"
                    android:textSize="13sp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchVad"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="固有名詞 (認識精度を上げる / 1行1つ)"
                android:textColor="#9CA3AF"
                android:textSize="12sp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                app:boxStrokeColor="#555555">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etProperNouns"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minLines="3"
                    android:gravity="top|start"
                    android:inputType="textMultiLine"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- ── 話者識別 ─────────────────────────────────────────────── -->

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="32dp"
                android:background="#1F1F1F" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="話者識別"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="誰が喋ったかを声紋で識別する (テレビ/動画/来客は「不明」)"
                    android:textColor="#DDDDDD"
                    android:textSize="13sp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchSpeakerId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSpeakerRegister"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="話者を登録 (純・あやか・おかん…)"
                android:textColor="#4CAF50"
                app:strokeColor="#4CAF50" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="識別のきびしさ (高いほど厳格 / 既定0.45)"
                    android:textColor="#9CA3AF"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvThresholdValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.45"
                    android:textColor="#4CAF50"
                    android:textSize="13sp"
                    android:fontFamily="monospace" />

            </LinearLayout>

            <SeekBar
                android:id="@+id/seekThreshold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:max="60"
                android:progress="45"
                android:progressTint="#4CAF50"
                android:thumbTint="#4CAF50" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="14dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="要約から「不明」話者を除外する (テレビ/動画を要約に入れない)"
                    android:textColor="#DDDDDD"
                    android:textSize="13sp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchExcludeUnknown"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false" />

            </LinearLayout>

            <!-- ── ストレージ管理 ───────────────────────────────────────── -->

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="32dp"
                android:background="#1F1F1F" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStorage"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="start|center_vertical"
                android:paddingHorizontal="4dp"
                android:text="ストレージ管理"
                android:textColor="#E5E5E5"
                android:textSize="14sp" />

            <!-- ── 保存 ──────────────────────────────────────────────────── -->

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="36dp"
                android:text="閉じる" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
