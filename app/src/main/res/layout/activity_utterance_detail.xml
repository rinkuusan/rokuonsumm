<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0F0F0F"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#0F0F0F"
        app:titleTextColor="#F0F0F0"
        app:titleTextAppearance="@style/TextAppearance.MaterialComponents.Headline6"
        app:navigationIconTint="#F0F0F0" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="24dp"
        android:paddingTop="8dp"
        android:paddingBottom="20dp">

        <TextView
            android:id="@+id/tvText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E5E5E5"
            android:textSize="17sp"
            android:lineSpacingMultiplier="1.7"
            android:textIsSelectable="true" />

    </androidx.core.widget.NestedScrollView>

    <!-- ── 話者行 (ラベル + 命名ボタン) ────────────────────────── -->
    <LinearLayout
        android:id="@+id/speakerBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:paddingVertical="8dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvSpeaker"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#9CA3AF"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNameSpeaker"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="名前を付ける"
            android:textColor="#4CAF50"
            android:textSize="13sp"
            android:visibility="gone" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1A1A1A" />

    <!-- ── プレイヤー（画面下部に常駐） ────────────────────────── -->
    <LinearLayout
        android:id="@+id/playerSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#141414"
        android:paddingBottom="14dp">

        <com.rokuonsumm.ui.WaveformView
            android:id="@+id/waveformView"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="14dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="4dp" />

        <SeekBar
            android:id="@+id/seekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:progressTint="#4CAF50"
            android:thumbTint="#4CAF50" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp">

            <TextView
                android:id="@+id/tvCurrentTime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0:00"
                android:textColor="#88FFFFFF"
                android:textSize="11sp"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/tvTotalTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="#88FFFFFF"
                android:textSize="11sp"
                android:fontFamily="monospace" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingTop="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRewind"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-10"
                android:textColor="#AAFFFFFF"
                android:textSize="13sp" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabPlayPause"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:src="@drawable/ic_play"
                app:backgroundTint="#2E7D32"
                app:tint="@android:color/white"
                app:fabSize="normal" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFastForward"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+10"
                android:textColor="#AAFFFFFF"
                android:textSize="13sp" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvNoAudio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingVertical="20dp"
            android:text="この録音の音声ファイルは削除されています"
            android:textColor="#6B7280"
            android:textSize="13sp"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>
